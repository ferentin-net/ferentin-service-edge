# Ferentin Service Edge Configuration
# Copy this file to .env and update values.
#
# Only two values are required for first-time enrollment:
#   ENROLLMENT_TOKEN        — single-use JWT from admin console (15-min TTL)
#   FERENTIN_KEY_PASSPHRASE — passphrase for at-rest key encryption
#
# Tenant ID, site ID, edge ID and edge type are derived from the JWT claims
# (tid, site_id, edge_id, edge_type) at bootstrap. Don't set them as env vars
# — any mismatch with the token aborts startup.

# Required: Bootstrap enrollment token (obtain from admin console).
# Bootstrap auto-triggers when this is set and no certs are on the volume.
# After enrollment the token is harmless (the runner short-circuits on valid
# certs); you can leave it in place or remove it on subsequent starts.
ENROLLMENT_TOKEN=

# Required: Passphrase for private key encryption at rest (minimum 32 characters).
# Generate with: openssl rand -base64 48
# IMPORTANT: Store securely. If lost, the edge must re-enroll.
FERENTIN_KEY_PASSPHRASE=

# Required: Spring profile (determines control plane URL)
# - aws-secure: Production (https://cp.ferentin.net)
# - nginx: Local development (https://cp.local.ferentin.test)
SPRING_PROFILES_ACTIVE=aws-secure

# Required: Image version — pin to a specific release
# See https://github.com/ferentin-net/service-edge/releases
SERVICE_EDGE_VERSION=0.5.4

# Optional: Custom JVM options
# JAVA_OPTS=-Xmx1g -Xms512m

# Optional: Enable virtual threads (Java 25)
# ENABLE_VIRTUAL_THREADS=true

# Optional: Custom CA bundle (PEM format, base64 encoded)
# Only needed if using self-signed certificates
# EDGE_CA_BUNDLE=LS0tLS1CRUdJTi...
